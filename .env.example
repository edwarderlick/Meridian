# Copy this file to .env and fill in real values. .env is gitignored — never commit it.

# --- Phase 1: Wallet connection (this phase) ---------------------------------
# WalletConnect Cloud project ID, used by RainbowKit's connector list.
# Get one at https://cloud.walletconnect.com
VITE_WALLETCONNECT_PROJECT_ID=

# Optional: dedicated Solana Devnet RPC (e.g. a free-tier Helius/QuickNode/Alchemy
# endpoint) — falls back to the public api.devnet.solana.com endpoint if unset.
# The public endpoint is rate-limited and known to be unreliable under repeated
# testing; set this if you're hitting "RPC endpoint error" failures on the Solana
# leg of a bridge.
VITE_SOLANA_RPC_URL=

# Optional: dedicated RPC endpoints for the 7 EVM testnets (e.g. free-tier
# Alchemy/Infura) — each falls back to its chain's public default RPC if unset.
# Same rate-limiting problem as Solana above: viem's built-in public endpoints
# (and Arc's own rpc.testnet.arc.network) are shared infrastructure that starts
# throwing "RPC endpoint error" / simulation failures under heavy repeated bridge
# testing. Arbitrum Sepolia and Polygon Amoy are the ones observed failing so
# far — set those two first if you can only get keys for a couple of chains.
VITE_ARC_TESTNET_RPC_URL=
VITE_ETHEREUM_SEPOLIA_RPC_URL=
VITE_ARBITRUM_SEPOLIA_RPC_URL=
VITE_BASE_SEPOLIA_RPC_URL=
VITE_OPTIMISM_SEPOLIA_RPC_URL=
VITE_AVALANCHE_FUJI_RPC_URL=
VITE_POLYGON_AMOY_RPC_URL=

# --- Later phases: balances, transaction submission --------------------------
# Circle API key (Circle Console > API Keys). Server-side ONLY — deliberately
# NOT prefixed with VITE_, so Vite never inlines it into the client bundle.
# The frontend calls Circle through the local /api/circle proxy (see
# api/_lib/circleHandler.js) instead of hitting Circle's API directly.
CIRCLE_API_KEY=

# --- Later phases: Firestore-backed transaction history / activity feeds -----
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# --- Phase 5: wallet <-> Firebase Auth bridging (SIWE-style sign-in) --------
# Server-side ONLY — never VITE_-prefixed, never sent to the client. This backs
# the /api/auth/nonce and /api/auth/verify endpoints, which mint Firebase custom
# tokens after verifying a wallet signature. Generate from Firebase Console >
# Project Settings > Service Accounts > Generate New Private Key, then paste the
# full JSON file contents here as a single-line string (JSON.parse'd at runtime).
FIREBASE_SERVICE_ACCOUNT_KEY=

# --- Server-side only — DO NOT add to this file, DO NOT prefix with VITE_ ----
# GEMINI_API_KEY belongs in the serverless/Express backend's own environment,
# never in the Vite client bundle. Any env var prefixed VITE_ is inlined into
# the client-side JS bundle at build time and is publicly readable by anyone —
# a VITE_GEMINI_API_KEY would leak the key to every visitor's browser.
# GEMINI_API_KEY=  (set this in the backend's environment, not here)
