# Copy to .env (gitignored, never commit it). This subproject's env is deliberately isolated from
# the frontend's — DEPLOYER_PRIVATE_KEY must never end up anywhere near the Vite/VITE_ world.

# A funded, TESTNET-ONLY wallet's private key. Fund it via https://faucet.circle.com/ (Arc Testnet
# USDC also covers gas — Arc's native gas token IS USDC). Never use a key that holds real value,
# and never paste it into chat — it only ever belongs in this local .env file.
DEPLOYER_PRIVATE_KEY=

# Defaults to the public Arc Testnet RPC if unset — same fallback the frontend uses.
ARC_TESTNET_RPC_URL=
