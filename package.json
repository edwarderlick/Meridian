    "firebase-admin": "^14.1.0",
    "gsap": "^3.15.0",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.8",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.18.1",
    "viem": "^2.55.0",
    "wagmi": "^2.19.5"
