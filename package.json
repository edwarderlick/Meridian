    "@circle-fin/adapter-solana-kit": "^1.5.2",
    "@circle-fin/adapter-viem-v2": "^1.13.0",
    "@circle-fin/bridge-kit": "^1.12.0",
    "@circle-fin/swap-kit": "^1.4.0",
    "@circle-fin/unified-balance-kit": "^1.2.2",
    "@gsap/react": "^2.1.2",
    "@mysten/dapp-kit": "^1.1.5",
    "@mysten/sui": "^2.20.3",
    "@rainbow-me/rainbowkit": "^2.2.11",
    "@solana/wallet-adapter-base": "^0.9.27",
    "@solana/wallet-adapter-react": "^0.15.39",
    "@solana/wallet-adapter-react-ui": "^0.9.39",
    "@solana/wallet-adapter-wallets": "^0.19.38",
    "@solana/wallet-standard-features": "^1.4.0",
