+/**
+ * LOCAL PATCH (via patch-package) — Creates a SetComputeUnitPrice instruction for the Compute
+ * Budget Program. This SDK never builds one anywhere, which means every transaction it submits is
+ * "unpriced". Wallets such as Phantom and Solflare detect that and silently inject their own
+ * priority-fee instruction before signing (permitted by the Wallet Standard spec: "allows...
+ * wallets that use meta-transactions to return a modified, signed transaction"). Circle's own
+ * `createExecute` signs the fee payer and any additional signers (e.g. CCTP's ephemeral message
+ * account, via `collectAdditionalSignatures`) against two SEPARATE compiles of the same intended
+ * message; if the wallet changes the message while signing the fee payer's half, the additional
+ * signer's signature (already computed against the original) no longer matches, and the cluster
+ * rejects the transaction with "Transaction did not pass signature verification" — confirmed
+ * directly via an ED25519 check and a raw-byte before/after comparison during signing. Always
+ * including a price instruction ourselves removes the wallet's reason to modify anything.
+ *
+ * @param microLamports - Price per compute unit, in micro-lamports (must fit in u64).
+ * @returns A `@solana/kit` Instruction for the SetComputeUnitPrice operation.
+ */ function createSetComputeUnitPriceInstruction(microLamports) {
+    const value = BigInt(microLamports);
+    if (value < 0n || value > 0xffffffffffffffffn) {
+        throw createValidationFailedError('computeUnitPrice', microLamports, 'Must be a positive number that fits in u64');
+    }
+    const data = new Uint8Array(9);
+    // Discriminator for SetComputeUnitPrice is 3
+    data[0] = 3;
+    const view = new DataView(data.buffer);
+    view.setBigUint64(1, value, true) // true = little-endian
+    ;
+    return {
+        programAddress: address(COMPUTE_BUDGET_PROGRAM_ID),
+        accounts: [],
+        data
+    };
+}
+
